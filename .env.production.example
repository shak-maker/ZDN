# =============================================================================
# ZDN — Production environment template
# =============================================================================
# Copy to .env on the production server. Use strong secrets.
# =============================================================================

NODE_ENV=production
API_PORT=80

MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=zdn_db
MYSQL_USER=zdn_user
MYSQL_PASSWORD=

DATABASE_URL=mysql://zdn_user:YOUR_PASSWORD@mysql:3306/zdn_db
JWT_SECRET=
API_KEY_SECRET=
JWT_EXPIRES_IN=24h
FRONTEND_URL=https://your-domain.com
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
LOG_LEVEL=info
