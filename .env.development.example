# =============================================================================
# ZDN — Development environment template
# =============================================================================
# For local or docker-compose.dev.yml. Optional: use SQLite for backend.
# =============================================================================

NODE_ENV=development
API_PORT=80

# MySQL (used by docker-compose.dev.yml)
MYSQL_ROOT_PASSWORD=devroot
MYSQL_DATABASE=zdn_db
MYSQL_USER=zdn_user
MYSQL_PASSWORD=zdn_password

# Backend — for Docker use mysql URL above; for local SQLite use:
# DATABASE_URL=file:./prisma/dev.db
DATABASE_URL=mysql://zdn_user:zdn_password@mysql:3306/zdn_db
JWT_SECRET=dev-jwt-secret-minimum-32-characters
API_KEY_SECRET=dev-api-key-secret
JWT_EXPIRES_IN=24h
FRONTEND_URL=http://localhost:5173
BCRYPT_ROUNDS=10
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=200
LOG_LEVEL=debug
