# =============================================================================
# ZDN — Environment template (copy to .env and fill)
# =============================================================================
# Development: copy to .env and use with docker-compose.dev.yml or local runs.
# Production: copy to .env on the server; never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=zdn_db
MYSQL_USER=zdn_user
MYSQL_PASSWORD=

# -----------------------------------------------------------------------------
# Backend (NestJS)
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://zdn_user:YOUR_PASSWORD@mysql:3306/zdn_db
JWT_SECRET=
API_KEY_SECRET=
JWT_EXPIRES_IN=24h
FRONTEND_URL=http://localhost
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Redis (caching, rate limiting, sessions)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Host / Port
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=80
